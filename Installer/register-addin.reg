Windows Registry Editor Version 5.00

; Đăng ký Local Word AI Add-in với Microsoft Word
; Chạy file này với quyền Administrator

[HKEY_CURRENT_USER\Software\Microsoft\Office\Word\Addins\LocalDocAI]
"Description"="Local AI Assistant for Microsoft Word - Offline"
"FriendlyName"="Local Word AI"
"LoadBehavior"=dword:00000003
"Manifest"="file:///C:\\Program Files\\LocalDocAI\\LocalDocAI.vsto|vstolocal"
